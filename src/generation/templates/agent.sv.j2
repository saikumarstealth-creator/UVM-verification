// UVM Agent for {{ spec.design_name }} ({{ spec.protocol|default("wishbone", true) }})
{% set p = spec.protocol|default("wishbone") %}
class {{ spec.design_name }}_agent extends uvm_agent;
  `uvm_component_utils({{ spec.design_name }}_agent)
  {{ spec.design_name }}_driver     driver;
  {{ spec.design_name }}_monitor    monitor;
  uvm_sequencer #({{ spec.design_name }}_seq_item) sequencer;

  function new(string n, uvm_component p); super.new(n, p); endfunction

  function void build_phase(uvm_phase phase);
    sequencer = uvm_sequencer#({{ spec.design_name }}_seq_item)::type_id::create("sequencer", this);
    driver    = {{ spec.design_name }}_driver::type_id::create("driver", this);
    monitor   = {{ spec.design_name }}_monitor::type_id::create("monitor", this);
  endfunction

  function void connect_phase(uvm_phase phase);
    driver.seq_item_port.connect(sequencer.seq_item_export);
  endfunction
endclass
