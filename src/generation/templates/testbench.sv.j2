// Generated UVM Testbench for {{ spec.design_name }} ({{ spec.protocol|default("wishbone", true) }})
`timescale 1ns/1ps
{% set p = spec.protocol|default("wishbone") %}

module testbench;
  logic clk;
  logic rst_n;

  // Interface
  {{ spec.design_name }}_intf intf(clk, rst_n);

  // Protocol Core DUT — auto-generated behavioral model
  {{ spec.design_name }}_core dut (
    .clk  (clk),
    .rst_n(rst_n),
     {% if p == "uart" %}
     .wb_cyc    (intf.wb_cyc),
     .wb_stb    (intf.wb_stb),
     .wb_we     (intf.wb_we),
     .wb_addr   (intf.wb_addr),
     .wb_data_i (intf.wb_data_o),
     .wb_data_o (intf.wb_data_i),
     .wb_ack    (intf.wb_ack),
     .uart_tx   (intf.uart_tx),
     .uart_rx   (intf.uart_rx),
     .cts_n     (intf.cts_n),
     .rts_n     (intf.rts_n),
     .uart_intr (intf.uart_intr)
    {% elif p == "spi" %}
    .wb_cyc    (intf.wb_cyc),
    .wb_stb    (intf.wb_stb),
    .wb_we     (intf.wb_we),
    .wb_addr   (intf.wb_addr),
    .wb_data_i (intf.wb_data_o),
    .wb_data_o (intf.wb_data_i),
    .wb_ack    (intf.wb_ack),
    .sclk      (intf.sclk),
    .mosi      (intf.mosi),
    .miso      (intf.miso),
    .ss_n      (intf.ss_n),
    .spi_intr  (intf.spi_intr)
    {% elif p == "i2c" %}
    .wb_cyc    (intf.wb_cyc),
    .wb_stb    (intf.wb_stb),
    .wb_we     (intf.wb_we),
    .wb_addr   (intf.wb_addr),
    .wb_data_i (intf.wb_data_o),
    .wb_data_o (intf.wb_data_i),
    .wb_ack    (intf.wb_ack),
    .scl       (intf.scl),
    .sda       (intf.sda),
    .i2c_intr  (intf.i2c_intr)
    {% elif p == "axi4lite" %}
    .awvalid   (intf.awvalid),
    .awready   (intf.awready),
    .awaddr    (intf.awaddr),
    .wvalid    (intf.wvalid),
    .wready    (intf.wready),
    .wdata     (intf.wdata),
    .bready    (intf.bready),
    .bvalid    (intf.bvalid),
    .bresp     (intf.bresp),
    .arvalid   (intf.arvalid),
    .arready   (intf.arready),
    .araddr    (intf.araddr),
    .rready    (intf.rready),
    .rvalid    (intf.rvalid),
    .rdata     (intf.rdata),
    .rresp     (intf.rresp),
    .axi_intr  (intf.axi_intr)
    {% elif p == "apb" %}
    .psel      (intf.psel),
    .penable   (intf.penable),
    .pwrite    (intf.pwrite),
    .paddr     (intf.paddr),
    .pwdata    (intf.pwdata),
    .prdata    (intf.prdata),
    .pready    (intf.pready),
    .pslverr   (intf.pslverr),
    .apb_intr  (intf.apb_intr)
    {% else %}
    .wb_cyc    (intf.wb_cyc),
    .wb_stb    (intf.wb_stb),
    .wb_we     (intf.wb_we),
    .wb_addr   (intf.wb_addr),
    .wb_data_i (intf.wb_data_o),
    .wb_data_o (intf.wb_data_i),
    .wb_ack    (intf.wb_ack),
    .wb_intr   (intf.wb_intr)
    {% endif %}
  );

  // UVM config + launch
  initial begin
    uvm_config_db#(virtual {{ spec.design_name }}_intf)::set(null, "*", "vif", intf);
    run_test();
  end

  initial begin clk = 0; forever #5 clk = ~clk; end
  initial begin
    rst_n = 0;
    repeat (10) @(posedge clk);
    rst_n = 1;
  end
  initial begin
    $dumpfile("sim.vcd");
    $dumpvars(0, testbench);
  end
endmodule
